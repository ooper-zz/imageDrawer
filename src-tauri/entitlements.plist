<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Enable App Sandbox (required for Mac App Store) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Allow reading/writing user-selected files (via open/save dialogs) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow outgoing network connections (for downloading tools) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow spawning child processes (required for running CLI tools) -->
    <!-- This is a temporary exception Apple may grant for developer tools -->
    <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
    <array>
        <string>com.apple.coreservices.launchservicesd</string>
    </array>

    <!-- Allow executing bundled and user-installed helper tools -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-only</key>
    <array>
        <string>/usr/bin/</string>
        <string>/bin/</string>
        <string>/usr/sbin/</string>
    </array>

    <!-- Allow read-write to the app's container -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
